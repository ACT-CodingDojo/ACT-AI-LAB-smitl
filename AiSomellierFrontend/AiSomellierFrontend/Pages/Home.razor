@page "/"
@inject HttpClient Http

<PageTitle>AiSomellier</PageTitle>

<h1>AiSomellier - Suggerimenti Vini</h1>

<div class="form-group">
    <label for="mealType">Tipo di Pasto:</label>
    <select @bind="request.MealType" id="mealType" class="form-control">
        <option value="">Seleziona...</option>
        <option value="carne">Carne</option>
        <option value="pesce">Pesce</option>
        <option value="vegetariano">Vegetariano</option>
        <option value="dessert">Dessert</option>
    </select>
</div>

<div class="form-group">
    <label for="occasion">Occasione:</label>
    <select @bind="request.Occasion" id="occasion" class="form-control">
        <option value="">Seleziona...</option>
        <option value="cena informale">Cena Informale</option>
        <option value="appuntamento">Appuntamento</option>
        <option value="festa">Festa</option>
    </select>
</div>

<div class="form-group">
    <label for="season">Stagione:</label>
    <select @bind="request.Season" id="season" class="form-control">
        <option value="">Seleziona...</option>
        <option value="primavera">Primavera</option>
        <option value="estate">Estate</option>
        <option value="autunno">Autunno</option>
        <option value="inverno">Inverno</option>
    </select>
</div>

<button @onclick="GetRecommendations" class="btn btn-primary">Ottieni Suggerimenti</button>

@if (recommendations != null && recommendations.Any())
{
    <h2>Suggerimenti:</h2>
    @foreach (var rec in recommendations)
    {
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@rec.Wine.Name</h5>
                <p class="card-text">@rec.Wine.Description</p>
                <p class="card-text"><strong>Ragione:</strong> @rec.Reason</p>
            </div>
        </div>
    }
}

@code {
    private RecommendationRequest request = new();
    private List<WineRecommendation>? recommendations;

    private string? errorMessage;

    private async Task GetRecommendations()
    {
        errorMessage = null;
        try
        {
            var response = await Http.PostAsJsonAsync("https://localhost:5001/recommendations", request);
            if (response.IsSuccessStatusCode)
            {
                recommendations = await response.Content.ReadFromJsonAsync<List<WineRecommendation>>();
            }
            else
            {
                errorMessage = $"Errore API: {response.StatusCode}";
                recommendations = new List<WineRecommendation>();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            recommendations = new List<WineRecommendation>();
        }
    }

    public class RecommendationRequest
    {
        public string MealType { get; set; } = string.Empty;
        public string Occasion { get; set; } = string.Empty;
        public string Season { get; set; } = string.Empty;
    }

    public class Wine
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Season { get; set; } = string.Empty;
        public string Intensity { get; set; } = string.Empty;
    }

    public class WineRecommendation
    {
        public Wine Wine { get; set; } = null!;
        public string Reason { get; set; } = string.Empty;
    }
}
